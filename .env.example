# Vercel KV (auto-set when you create a KV store in Vercel dashboard)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Vercel Blob (auto-set when you create a Blob store in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=

# Admin token for moderating guestbook & gallery (set this yourself)
ADMIN_TOKEN=your-secret-admin-token
