# Pull these with `vercel env pull` after connecting Upstash Redis and Vercel Blob.
# They are usually injected automatically in production and preview deployments.

# Upstash Redis via Vercel Marketplace integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Admin token for moderating guestbook and gallery submissions
ADMIN_TOKEN=replace-with-a-long-random-secret
